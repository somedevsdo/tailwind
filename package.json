{
  "name": "@somedevsdo/tailwind",
  "version": "0.1.0",
  "description": "somedevsdo brand tokens for Tailwind CSS v4.",
  "license": "MIT",
  "private": false,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "base.css",
    "tokens.json",
    "README.md",
    "AGENTS.md"
  ],
  "exports": {
    ".": "./base.css",
    "./base.css": "./base.css",
    "./tokens.json": "./tokens.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "tokens:extract": "node scripts/extract-brand-tokens.mjs",
    "build": "pnpm tokens:extract",
    "test:harness": "tailwindcss -i ./tests/harness/input.css -o ./tests/harness/output.css --minify && node ./scripts/verify-harness.mjs",
    "verify": "pnpm build && pnpm test:harness",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@tailwindcss/cli": "^4.1.13",
    "tailwindcss": "^4.1.13"
  }
}

{
  "source": "https://somedevsdo.com",
  "stylesheets": [
    "https://somedevsdo.com/_astro/about.CAYCtiUs.css"
  ],
  "light": {
    "size-padding-x-small": ".25rem",
    "size-padding-small": ".5rem",
    "size-padding-medium": ".75rem",
    "size-padding-large": "1rem",
    "size-padding-x-large": "1.25rem",
    "size-margin-x-small": ".5rem",
    "size-margin-small": "1rem",
    "size-margin-medium": "1.5rem",
    "size-margin-large": "2rem",
    "size-margin-x-large": "2.5rem",
    "line-height-header": "1.3",
    "line-height-text": "1.6",
    "font-family-default": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Oxygen, Ubuntu, Cantarell, Fira Sans, Droid Sans, Helvetica Neue, sans-serif",
    "font-family-header": "Poppins, var(--font-family-default)",
    "font-family-text": "\"Noto Sans\", var(--font-family-default)",
    "font-heading-x-small": "700 1.125rem / var(--line-height-header) var(--font-family-header)",
    "font-heading-small": "700 1.375rem / var(--line-height-header) var(--font-family-header)",
    "font-heading-medium": "700 1.75rem / var(--line-height-header) var(--font-family-header)",
    "font-heading-large": "700 2.25rem / var(--line-height-header) var(--font-family-header)",
    "font-heading-x-large": "700 2.75rem / var(--line-height-header) var(--font-family-header)",
    "font-text-x-small": ".75rem / var(--line-height-text) var(--font-family-text)",
    "font-text-small": ".875rem / var(--line-height-text) var(--font-family-text)",
    "font-text-medium": "1rem / var(--line-height-text) var(--font-family-text)",
    "font-text-large": "1.125rem / var(--line-height-text) var(--font-family-text)",
    "cod-gray": "#151515",
    "mine-shaft": "#151515",
    "dove-gray": "#666",
    "alto": "#ddd",
    "white": "#fff",
    "background": "var(--white)",
    "foreground": "var(--cod-gray)",
    "shadow": "rgba(0, 0, 0, .05)",
    "secondary-text": "var(--dove-gray)",
    "clr-palette-ebony": "#090d18",
    "clr-palette-ebony-clay": "#1f2132",
    "clr-palette-emporer": "#555",
    "clr-palette-silver": "#c6c6c6",
    "clr-palette-seance": "#7621ab",
    "clr-palette-perfume": "#d5a4f5",
    "clr-palette-mystic": "#e8edf2",
    "clr-palette-white": "#fff",
    "clr-background": "var(--clr-palette-mystic)",
    "clr-content-background": "var(--clr-palette-white)",
    "clr-header": "var(--clr-palette-ebony)",
    "clr-text": "var(--clr-palette-emporer)"
  },
  "dark": {
    "background": "var(--cod-gray)",
    "foreground": "var(--white)",
    "shadow": "rgba(255, 255, 255, .05)",
    "secondary-text": "var(--alto)",
    "clr-background": "var(--clr-palette-ebony)",
    "clr-content-background": "var(--clr-palette-ebony-clay)",
    "clr-header": "var(--clr-palette-mystic)",
    "clr-text": "var(--clr-palette-silver)"
  }
}
